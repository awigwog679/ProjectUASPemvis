<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="nota_penjualan" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="86a9b71c-37d6-4b89-8a74-69d11df877d1">
	<parameter name="id_nota" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     pelanggan.`nmplgn` AS pelanggan_nmplgn,
     pelanggan.`jenis` AS pelanggan_jenis,
     pelanggan.`telepon` AS pelanggan_telepon,
     pelanggan.`alamat` AS pelanggan_alamat,
     nota.`idnota` AS nota_idnota,
     nota.`tgl` AS nota_tgl,
     nota.`txtid` AS nota_txtid,
     nota.`id_kasir` AS nota_id_kasir,
     kasir.`Id_kasir` AS kasir_Id_kasir,
     kasir.`nama_kasir` AS kasir_nama_kasir,
     kasir.`jenis_kelamin` AS kasir_jenis_kelamin,
     kasir.`no_telp` AS kasir_no_telp,
     kasir.`agama` AS kasir_agama,
     kasir.`password` AS kasir_password,
     kasir.`alamat` AS kasir_alamat,
     isi.`kd_brg` AS isi_kd_brg,
     isi.`h_beli` AS isi_h_beli,
     isi.`h_jual` AS isi_h_jual,
     isi.`qty` AS isi_qty,
     barang.`id` AS barang_id,
     barang.`nmbrg` AS barang_nmbrg,
     barang.`jenis` AS barang_jenis,
     barang.`harga_beli` AS barang_harga_beli,
     barang.`harga_jual` AS barang_harga_jual,
     pelanggan.`id` AS pelanggan_id,
     isi.`idnota` AS isi_idnota
FROM
     `nota` nota INNER JOIN `isi` isi ON nota.`idnota` = isi.`idnota`
     INNER JOIN `kasir` kasir ON nota.`id_kasir` = kasir.`Id_kasir`
     INNER JOIN `pelanggan` pelanggan ON nota.`txtid` = pelanggan.`id`
     INNER JOIN `barang` barang ON isi.`kd_brg` = barang.`id`
WHERE nota.idnota=$P{id_nota}]]>
	</queryString>
	<field name="pelanggan_nmplgn" class="java.lang.String"/>
	<field name="pelanggan_jenis" class="java.lang.String"/>
	<field name="pelanggan_telepon" class="java.lang.String"/>
	<field name="pelanggan_alamat" class="java.lang.String"/>
	<field name="nota_idnota" class="java.lang.String"/>
	<field name="nota_tgl" class="java.sql.Date"/>
	<field name="nota_txtid" class="java.lang.String"/>
	<field name="nota_id_kasir" class="java.lang.String"/>
	<field name="kasir_Id_kasir" class="java.lang.String"/>
	<field name="kasir_nama_kasir" class="java.lang.String"/>
	<field name="kasir_jenis_kelamin" class="java.lang.String"/>
	<field name="kasir_no_telp" class="java.lang.String"/>
	<field name="kasir_agama" class="java.lang.String"/>
	<field name="kasir_password" class="java.lang.String"/>
	<field name="kasir_alamat" class="java.lang.String"/>
	<field name="isi_kd_brg" class="java.lang.String"/>
	<field name="isi_h_beli" class="java.lang.Integer"/>
	<field name="isi_h_jual" class="java.lang.Integer"/>
	<field name="isi_qty" class="java.lang.Integer"/>
	<field name="barang_id" class="java.lang.String"/>
	<field name="barang_nmbrg" class="java.lang.String"/>
	<field name="barang_jenis" class="java.lang.String"/>
	<field name="barang_harga_beli" class="java.lang.Integer"/>
	<field name="barang_harga_jual" class="java.lang.Integer"/>
	<field name="pelanggan_id" class="java.lang.String"/>
	<field name="isi_idnota" class="java.lang.String"/>
	<variable name="subtotal" class="java.lang.Integer">
		<variableExpression><![CDATA[$F{isi_qty} * $F{isi_h_jual}]]></variableExpression>
	</variable>
	<variable name="total_belanja" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$V{subtotal}]]></variableExpression>
	</variable>
